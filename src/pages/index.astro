---
import Layout from "../layouts/Layout.astro";
import Panel from "../components/Panel.astro";
---

<Layout title="Better Split">
	<div class="shell" x-data="app" :data-stage="stage" data-stage="onboarding">
		<header class="topbar">
			<div class="brand">
				<span class="brand-mark">B</span>
				<span>better<span class="slash">/</span>split</span>
			</div>
			<div class="topbar-meta" x-show="stage === 'onboarding'">
				<span class="dot"></span>
				<span>Nothing leaves this tab</span>
				<button class="theme-toggle" type="button"
					:aria-label="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
					:title="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
					@click="toggleTheme()">
					<svg x-show="theme === 'light'" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 9.5A5.5 5.5 0 1 1 6.5 2.5a4.5 4.5 0 0 0 7 7Z"/></svg>
					<svg x-show="theme === 'dark'" x-cloak viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="8" r="3"/><path d="M8 1.5v1.5M8 13v1.5M1.5 8h1.5M13 8h1.5M3.3 3.3l1.1 1.1M11.6 11.6l1.1 1.1M3.3 12.7l1.1-1.1M11.6 4.4l1.1-1.1"/></svg>
				</button>
			</div>
			<div class="topbar-meta" x-show="stage === 'workspace'" x-cloak>
				<span class="topbar-group" x-text="groupName || 'Untitled'"></span>
				<span class="topbar-sep">·</span>
				<span x-text="countsLabel"></span>
				<button class="theme-toggle" type="button"
					:aria-label="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
					:title="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
					@click="toggleTheme()">
					<svg x-show="theme === 'light'" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13.5 9.5A5.5 5.5 0 1 1 6.5 2.5a4.5 4.5 0 0 0 7 7Z"/></svg>
					<svg x-show="theme === 'dark'" x-cloak viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="8" r="3"/><path d="M8 1.5v1.5M8 13v1.5M1.5 8h1.5M13 8h1.5M3.3 3.3l1.1 1.1M11.6 11.6l1.1 1.1M3.3 12.7l1.1-1.1M11.6 4.4l1.1-1.1"/></svg>
				</button>
				<button class="btn ghost small" type="button" @click="resetAll()">Reset</button>
			</div>
		</header>

		<div class="welcome" x-show="stage === 'onboarding'">
			<h1>Set up your group.</h1>
			<p>Name it and add everyone involved. You can edit anything later.</p>
		</div>

		<aside class="resume-card" x-show="resumeVisible" x-cloak>
			<div class="resume-info">
				<span class="resume-label">Continue last session</span>
				<strong x-text="resumeSnapshot?.groupName || 'Untitled group'"></strong>
				<span class="resume-meta" x-text="resumeCounts"></span>
			</div>
			<div class="resume-actions">
				<button class="btn secondary small" type="button" @click="resumeDismiss()">Start fresh</button>
				<button class="btn small" type="button" @click="resumeConfirm()">
					Resume
					<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
				</button>
			</div>
		</aside>

		<main class="layout">
			<div class="col col-group">
				<Panel title="Group" titleId="group-title">
					<div class="field">
						<label class="field-label" for="group-name">Group name</label>
						<input id="group-name" type="text" placeholder="Weekend in Bali" autocomplete="off" x-model="groupName" />
					</div>

					<form class="inline-add" @submit.prevent="addMember()">
						<div class="field">
							<label class="field-label" for="member-name">Add member</label>
							<input id="member-name" type="text" placeholder="Sarah" autocomplete="off" x-model="memberNameInput" />
						</div>
						<button class="btn" type="submit">Add</button>
					</form>

					<div class="members">
						<template x-if="members.length === 0">
							<div class="empty">No one in the group yet.</div>
						</template>
						<template x-for="m in members" :key="m.id">
							<div class="member">
								<span class="avatar" :style="avatarStyle(m.id)" aria-hidden="true" x-text="initialsOf(m.name)"></span>
								<span class="member-name" x-text="m.name"></span>
								<button class="icon-btn" type="button" :aria-label="'Remove ' + m.name" title="Remove" @click="removeMember(m.id)">
									<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 3l8 8M11 3l-8 8"/></svg>
								</button>
							</div>
						</template>
					</div>
					<div class="message" role="status" :class="messageClass(memberMessage)" x-text="memberMessage.text"></div>
				</Panel>

				<button class="btn continue-btn" type="button"
					x-show="stage === 'onboarding'"
					:disabled="!continueReady"
					@click="continueToWorkspace()">
					Continue
					<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
				</button>
				<p class="continue-hint" x-show="stage === 'onboarding'" x-text="continueHint"></p>
			</div>

			<div class="col col-form" x-show="stage === 'workspace'" x-cloak>
				<Panel title="Add expense" titleId="expense-title">
					<form @submit.prevent="submitExpense()" style="display: grid; gap: 14px;">
						<div class="field">
							<label class="field-label" for="expense-description">Description</label>
							<input id="expense-description" type="text" placeholder="Dinner, cab, groceries" autocomplete="off" x-model="expenseDescription" />
						</div>

						<div class="field">
							<span class="field-label">Who paid</span>
							<div style="display: grid; gap: 8px;">
								<template x-if="members.length === 0">
									<div class="empty">Add members to record an expense.</div>
								</template>
								<template x-for="row in payerRows" :key="row.id">
									<div class="payer-row">
										<select name="payer" aria-label="Payer" x-model="row.memberId">
											<template x-for="m in members" :key="m.id">
												<option :value="m.id" x-text="m.name"></option>
											</template>
										</select>
										<input name="amount" type="number" min="0" step="0.01" placeholder="0.00" inputmode="decimal" aria-label="Amount" x-model="row.amount" />
										<button class="icon-btn" type="button" aria-label="Remove payer row" title="Remove" @click="removePayerRow(row.id)">
											<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 3l8 8M11 3l-8 8"/></svg>
										</button>
									</div>
								</template>
							</div>
							<div class="row" style="margin-top: 4px;">
								<button class="btn ghost" type="button" :disabled="members.length === 0" @click="addPayerRow()">+ Add payer</button>
								<span class="total-pill">Paid <span x-text="paidTotalDisplay">0.00</span></span>
							</div>
						</div>

						<div class="field">
							<span class="field-label">Split equally between</span>
							<div class="split-options">
								<template x-if="members.length === 0">
									<div class="empty">Add members to choose who shares this.</div>
								</template>
								<template x-for="m in members" :key="m.id">
									<label class="chip">
										<input type="checkbox" :value="m.id" x-model="selectedSplitIds" />
										<span class="avatar" :style="avatarStyle(m.id)" aria-hidden="true" x-text="initialsOf(m.name)"></span>
										<span x-text="m.name"></span>
									</label>
								</template>
							</div>
						</div>

						<div class="form-actions">
							<button class="btn secondary" type="button" :disabled="members.length === 0" @click="selectAllSplit()">Everyone</button>
							<button class="btn grow" type="submit" :disabled="members.length < 2">
								Add transaction
								<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
							</button>
						</div>

						<div class="message" role="status" :class="messageClass(expenseMessage)" x-text="expenseMessage.text"></div>
					</form>
				</Panel>
			</div>

			<div class="col col-summary" x-show="stage === 'workspace'" x-cloak>
				<Panel title="Per-person share" titleId="balances-title">
					<template x-if="members.length === 0">
						<div class="empty">Balances appear once members are added.</div>
					</template>
					<template x-if="members.length > 0">
						<div class="balance-list">
							<template x-for="b in balances" :key="b.memberId">
								<div class="balance-row">
									<div class="balance-name">
										<span class="avatar" :style="avatarStyle(b.memberId)" aria-hidden="true" x-text="initialsOf(memberName(b.memberId))"></span>
										<span x-text="memberName(b.memberId)"></span>
									</div>
									<div class="balance-bar" aria-hidden="true">
										<div class="center"></div>
										<template x-if="b.net !== 0">
											<div class="fill" :class="balanceClass(b.net)" :style="`width: ${balancePct(b.net)}%;`"></div>
										</template>
									</div>
									<div class="balance-net" :class="balanceClass(b.net)">
										<span x-text="balanceSign(b.net) + money(Math.abs(b.net))"></span>
									</div>
								</div>
							</template>
						</div>
					</template>
				</Panel>

				<Panel title="Settle up" titleId="settle-title">
					<template x-if="expenses.length === 0">
						<div class="empty">Add transactions to settle.</div>
					</template>
					<template x-if="expenses.length > 0 && settlements.length === 0">
						<div class="empty">All settled — nobody owes anyone.</div>
					</template>
					<template x-if="expenses.length > 0 && settlements.length > 0">
						<div class="settlements">
							<template x-for="s in settlements" :key="s.from + '-' + s.to + '-' + s.amount">
								<div class="settle">
									<div class="who">
										<span class="avatar" :style="avatarStyle(s.from)" aria-hidden="true" x-text="initialsOf(memberName(s.from))"></span>
										<span class="name" x-text="memberName(s.from)"></span>
									</div>
									<span class="arrow" aria-hidden="true">→</span>
									<div class="who">
										<span class="avatar" :style="avatarStyle(s.to)" aria-hidden="true" x-text="initialsOf(memberName(s.to))"></span>
										<span class="name" x-text="memberName(s.to)"></span>
									</div>
									<span class="amount" x-text="money(s.amount)"></span>
								</div>
							</template>
						</div>
					</template>
				</Panel>

				<Panel title="Transactions" titleId="transactions-title">
					<span slot="count" class="count" x-text="expenses.length">0</span>
					<div class="txn-list">
						<template x-if="expenses.length === 0">
							<div class="empty">No transactions yet.</div>
						</template>
						<template x-for="expense in expenses" :key="expense.id">
							<article class="txn">
								<h3 class="txn-title" x-text="expense.description"></h3>
								<span class="txn-amount" x-text="money(expense.totalCents)"></span>
								<div class="txn-meta">
									<template x-for="(p, i) in expense.payers" :key="i">
										<span>
											<span class="sep" x-show="i > 0">·</span>
											<span><strong x-text="memberName(p.memberId)"></strong> paid <span x-text="money(p.amountCents)"></span></span>
										</span>
									</template>
									<span class="sep">·</span>
									<span>split <span x-text="expense.splitMemberIds.map((id) => memberName(id)).join(', ')"></span></span>
								</div>
								<div class="txn-actions">
									<button class="btn secondary small" type="button" @click="deleteExpense(expense.id)">Delete</button>
								</div>
							</article>
						</template>
					</div>
				</Panel>
			</div>
		</main>
	</div>

	<style is:global>
		[x-cloak] { display: none !important; }
	</style>
</Layout>
